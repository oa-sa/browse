{
  "builds": [
    {
      "src": "index.py",
      "use": "@vercel/python",
      "config": { "runtime": "python3.12" }
    },
    {
      "src": "static/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/", "dest": "/static/index.html" },
    { "src": "/services/(.*)", "dest": "index.py" }
  ]
}
